# Public application origins. In production both should be your HTTPS app origin.
NEXT_PUBLIC_BASE_URL=https://gotogethertrip.com
NEXT_PUBLIC_APP_URL=https://gotogethertrip.com

# Database. Production requires verify-full; set PGSSLROOTCERT or PGSSLCA when your provider uses a private/self-signed CA chain.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full
PGSSLMODE=verify-full
# Optional but required for private/self-signed database CA chains.
PGSSLROOTCERT=/etc/secrets/postgres-ca.pem
# Managed free-tier fallback when the CA chain is not available. Prefer PGSSLROOTCERT/PGSSLCA when possible.
ALLOW_UNVERIFIED_DATABASE_SSL=false
PG_POOL_MAX=5

# Runtime
NODE_ENV=production
PORT=3000
WEB_CONCURRENCY=2
TRUST_PROXY=true
SUPER_ADMIN_EMAIL=admin@example.com
SESSION_SECRET=replace_with_at_least_32_random_characters
CRON_SECRET=replace_with_at_least_32_random_characters
PAYMENTS_MASTER_KEY=replace_with_at_least_32_random_characters
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=base64_encoded_16_24_or_32_byte_key
NEXT_DEPLOYMENT_ID=git_sha_or_release_id

# Payments
# Use ORGANIZER_OWNED for direct organizer gateway collection.
# Use PLATFORM_CONTROLLED only when customers pay the GoTogether platform account.
PAYMENT_MODE=ORGANIZER_OWNED
PAYMENT_PROVIDER=RAZORPAY
ENABLED_ORGANIZER_PAYMENT_PROVIDERS=RAZORPAY,CASHFREE
NEXT_PUBLIC_ENABLED_ORGANIZER_PAYMENT_PROVIDERS=RAZORPAY,CASHFREE

RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

CASHFREE_ENV=production
CASHFREE_APP_ID=replace_with_cashfree_app_id
CASHFREE_SECRET_KEY=replace_with_cashfree_secret_key
CASHFREE_API_VERSION=2023-08-01



# OAuth, maps, and email
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace_with_browser_restricted_google_maps_key
RESEND_API_KEY=replace_with_resend_key
RESEND_FROM_EMAIL=GoTogether <no-reply@example.com>

# Media uploads
CLOUDINARY_CLOUD_NAME=replace_with_cloudinary_cloud
CLOUDINARY_API_KEY=replace_with_cloudinary_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_secret
